#ifndef SILVEROS_STL_ARRAY
#define SILVEROS_STL_ARRAY

#include <stddef.h>

namespace std {

template<typename T, size_t N>
struct array {
    T elems[N ? N : 1];

    constexpr T* data() noexcept { return elems; }
    constexpr const T* data() const noexcept { return elems; }
    constexpr size_t size() const noexcept { return N; }

    constexpr T& operator[](size_t i) noexcept { return elems[i]; }
    constexpr const T& operator[](size_t i) const noexcept { return elems[i]; }
};

} // namespace std

#endif
