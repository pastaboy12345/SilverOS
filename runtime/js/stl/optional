#ifndef SILVEROS_STL_OPTIONAL
#define SILVEROS_STL_OPTIONAL

namespace std {

struct nullopt_t {
    explicit constexpr nullopt_t(int) {}
};
constexpr nullopt_t nullopt{0};

template<typename T>
class optional {
public:
    constexpr optional() noexcept : has_(false), dummy_(0) {}
    constexpr optional(nullopt_t) noexcept : has_(false), dummy_(0) {}

    optional(const T& v) : has_(true) { new (&value_) T(v); }
    optional(T&& v) : has_(true) { new (&value_) T(static_cast<T&&>(v)); }

    constexpr bool has_value() const noexcept { return has_; }
    constexpr explicit operator bool() const noexcept { return has_; }

    T& value() { return value_; }
    const T& value() const { return value_; }

    T& operator*() { return value_; }
    const T& operator*() const { return value_; }

    void reset() noexcept {
        /* Intentionally does not destroy `T` in freestanding stub. */
        has_ = false;
    }

private:
    bool has_;
    union {
        char dummy_;
        T value_;
    };
};

} // namespace std

#endif
