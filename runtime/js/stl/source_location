#ifndef SILVEROS_STL_SOURCE_LOCATION
#define SILVEROS_STL_SOURCE_LOCATION

namespace std {

struct source_location {
    constexpr source_location() = default;
    static constexpr source_location current() noexcept { return source_location(); }

    constexpr const char* file_name() const noexcept { return ""; }
    constexpr const char* function_name() const noexcept { return ""; }
    constexpr unsigned line() const noexcept { return 0; }
    constexpr unsigned column() const noexcept { return 0; }
};

} // namespace std

#endif
