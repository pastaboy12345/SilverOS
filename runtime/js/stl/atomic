#ifndef SILVEROS_STL_ATOMIC
#define SILVEROS_STL_ATOMIC

namespace std {
    enum memory_order {
        memory_order_relaxed,
        memory_order_consume,
        memory_order_acquire,
        memory_order_release,
        memory_order_acq_rel,
        memory_order_seq_cst
    };

    template<typename T>
    struct atomic {
        volatile T value;
        atomic() noexcept : value(0) {}
        atomic(T v) noexcept : value(v) {}
        
        T load(memory_order = memory_order_seq_cst) const noexcept { return value; }
        void store(T v, memory_order = memory_order_seq_cst) noexcept { value = v; }
        
        T exchange(T v, memory_order = memory_order_seq_cst) noexcept {
            T old = value;
            value = v;
            return old;
        }

        bool compare_exchange_strong(T& expected, T desired, memory_order = memory_order_seq_cst) noexcept {
            if (value == expected) {
                value = desired;
                return true;
            }
            expected = value;
            return false;
        }

        bool compare_exchange_weak(T& expected, T desired, memory_order = memory_order_seq_cst) noexcept {
            return compare_exchange_strong(expected, desired);
        }

        T fetch_add(T v, memory_order = memory_order_seq_cst) noexcept {
            T old = value;
            value += v;
            return old;
        }

        T fetch_sub(T v, memory_order = memory_order_seq_cst) noexcept {
            T old = value;
            value -= v;
            return old;
        }

        T operator++(int) noexcept { return fetch_add(1); }
        T operator--(int) noexcept { return fetch_sub(1); }
        T operator+=(T v) noexcept { return fetch_add(v) + v; }
        T operator-=(T v) noexcept { return fetch_sub(v) - v; }
    };

    typedef atomic<bool>         atomic_bool;
    typedef atomic<char>         atomic_char;
    typedef atomic<int>          atomic_int;
    typedef atomic<long>         atomic_long;
    typedef atomic<unsigned int>  atomic_uint;
}

#endif
