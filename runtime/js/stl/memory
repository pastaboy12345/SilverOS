#ifndef SILVEROS_STL_MEMORY
#define SILVEROS_STL_MEMORY

#include <stddef.h>

namespace std {
    typedef decltype(nullptr) nullptr_t;

    template<typename T>
    class unique_ptr {
    public:
        constexpr unique_ptr() noexcept : ptr_(nullptr) {}
        constexpr unique_ptr(nullptr_t) noexcept : ptr_(nullptr) {}
        constexpr unique_ptr(int) noexcept : ptr_(nullptr) {} // For NULL/0
        
        explicit unique_ptr(T* p) noexcept : ptr_(p) {}
        
        template<typename U>
        unique_ptr(unique_ptr<U>&& other) noexcept : ptr_(other.release()) {}

        unique_ptr(unique_ptr&& other) noexcept : ptr_(other.release()) {}
        
        ~unique_ptr() { if (ptr_) delete ptr_; }

        unique_ptr& operator=(unique_ptr&& other) noexcept {
            if (static_cast<void*>(this) != static_cast<void*>(&other)) {
                if (ptr_) delete ptr_;
                ptr_ = other.release();
            }
            return *this;
        }

        template<typename U>
        unique_ptr& operator=(unique_ptr<U>&& other) noexcept {
            if (ptr_) delete ptr_;
            ptr_ = other.release();
            return *this;
        }

        unique_ptr& operator=(nullptr_t) noexcept {
            if (ptr_) delete ptr_;
            ptr_ = nullptr;
            return *this;
        }

        T* get() const noexcept { return ptr_; }
        T& operator*() const { return *ptr_; }
        T* operator->() const noexcept { return ptr_; }
        explicit operator bool() const noexcept { return ptr_ != nullptr; }
        
        T* release() noexcept {
            T* p = ptr_;
            ptr_ = nullptr;
            return p;
        }

        void reset(T* p = nullptr) noexcept {
            if (ptr_) delete ptr_;
            ptr_ = p;
        }

    private:
        T* ptr_;
        unique_ptr(const unique_ptr&) = delete;
        unique_ptr& operator=(const unique_ptr&) = delete;
        template<typename U> friend class unique_ptr;
    };

    template<typename T>
    class shared_ptr {
    public:
        shared_ptr() noexcept : ptr_(nullptr) {}
        shared_ptr(nullptr_t) noexcept : ptr_(nullptr) {}
        shared_ptr(int) noexcept : ptr_(nullptr) {}
        
        explicit shared_ptr(T* p) : ptr_(p) {}
        
        template<typename U>
        shared_ptr(const shared_ptr<U>& other) noexcept : ptr_(other.get()) {}
        
        shared_ptr(const shared_ptr& other) noexcept : ptr_(other.ptr_) {}
        
        shared_ptr(shared_ptr&& other) noexcept : ptr_(other.ptr_) {
            other.ptr_ = nullptr;
        }
        
        ~shared_ptr() {}

        shared_ptr& operator=(const shared_ptr& other) noexcept {
            ptr_ = other.ptr_;
            return *this;
        }
        
        template<typename U>
        shared_ptr& operator=(const shared_ptr<U>& other) noexcept {
            ptr_ = other.get();
            return *this;
        }

        shared_ptr& operator=(shared_ptr&& other) noexcept {
            ptr_ = other.ptr_;
            other.ptr_ = nullptr;
            return *this;
        }

        T* get() const noexcept { return ptr_; }
        T* operator->() const noexcept { return ptr_; }
        explicit operator bool() const noexcept { return ptr_ != nullptr; }

    private:
        T* ptr_;
        template<typename U> friend class shared_ptr;
    };

    template<typename T, typename... Args>
    unique_ptr<T> make_unique(Args&&... args) {
        return unique_ptr<T>(new T(static_cast<Args&&>(args)...));
    }

    template<typename T, typename... Args>
    shared_ptr<T> make_shared(Args&&... args) {
        return shared_ptr<T>(new T(static_cast<Args&&>(args)...));
    }

    // V8 TaskRunner and others might need move/forward.
    // BUT we saw in the error log that they might already be defined by <type_traits> or <bits/move.h>
    // However, since we are using our own STL headers, we should be fine if we don't include those.
    // Wait, the error log SHOWED they were included.
    
    inline void __throw_domain_error(const char* msg) { (void)msg; for(;;); }
    inline void __throw_invalid_argument(const char* msg) { (void)msg; for(;;); }
    inline void __throw_length_error(const char* msg) { (void)msg; for(;;); }
    inline void __throw_out_of_range(const char* msg) { (void)msg; for(;;); }
    inline void __throw_runtime_error(const char* msg) { (void)msg; for(;;); }
    inline void __throw_bad_alloc() { for(;;); }
}

#endif
